# Copy this file to .env before running docker compose
# This MVP works with mock reasoning and does not require real API credentials

########################################
# Application
########################################

APP_NAME=incident-reasoning-agent
APP_ENV=local
APP_PORT=8000
LOG_LEVEL=INFO

########################################
# Agent behavior
########################################

USE_MOCK_REASONING=true
REASONING_STRATEGY=sre_diagnostic

########################################
# Model configuration (optional)
########################################

MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=800

########################################
# API Keys (not required for MVP)
########################################

OPENAI_API_KEY=mock
OPENROUTER_API_KEY=mock

########################################
# Paths
########################################

PROMPT_FILE=prompts/incident_reasoning_prompt.md
OUTPUT_DIR=output
DATA_DIR=data

########################################
# Observability simulation
########################################

ENABLE_SIGNAL_LOGS=true
ENABLE_SIGNAL_CONFIG=true
ENABLE_SIGNAL_PAYLOAD=true

########################################
# Future integrations (disabled)
########################################

ENABLE_VECTOR_MEMORY=false
ENABLE_EXTERNAL_TOOLS=false
ENABLE_TICKET_INTEGRATION=false